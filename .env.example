# =============================================
# TOKO ATHIFABATTERY — Environment Variables
# Copy file ini menjadi .env.local
# JANGAN commit .env.local ke GitHub!
# =============================================

# Supabase (wajib)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App URL
NEXT_PUBLIC_APP_URL=https://athifabattery.vercel.app

# Telegram Bot (opsional — untuk notifikasi pesanan)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Admin credentials (untuk Supabase Auth)
# Daftarkan manual di: Supabase Dashboard → Authentication → Users
